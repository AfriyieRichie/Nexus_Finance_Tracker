generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum AccountClass {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountType {
  BANK
  CASH
  RECEIVABLE
  PAYABLE
  INVENTORY
  FIXED_ASSET
  INTANGIBLE
  RIGHT_OF_USE_ASSET
  EQUITY_ACCOUNT
  REVENUE_ACCOUNT
  COST_OF_SALES
  EXPENSE_ACCOUNT
  TAX_PAYABLE
  TAX_RECEIVABLE
  INTERCOMPANY
  OTHER
}

enum JournalType {
  GENERAL
  SALES
  PURCHASE
  CASH_RECEIPT
  CASH_PAYMENT
  BANK
  PAYROLL
  DEPRECIATION
  ADJUSTMENT
  REVERSAL
  OPENING_BALANCE
  CLOSING
}

enum EntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
  REJECTED
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  FINANCE_MANAGER
  ACCOUNTANT
  ACCOUNTS_PAYABLE_CLERK
  ACCOUNTS_RECEIVABLE_CLERK
  AUDITOR
  APPROVER
  REPORT_VIEWER
}

enum ApprovalEntityType {
  JOURNAL_ENTRY
  PAYMENT
  PURCHASE_ORDER
  BUDGET
  SALES_INVOICE
  EXPENSE_CLAIM
  PAYROLL
  BANK_TRANSFER
  SUPPLIER_INVOICE
}

enum ApprovalType {
  ANY_ONE
  ALL_REQUIRED
  MAJORITY
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  WITHDRAWN
}

enum ApprovalDecisionType {
  APPROVED
  REJECTED
  DELEGATED
}

enum NotificationType {
  APPROVAL_REQUESTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  APPROVAL_ESCALATED
  APPROVAL_DELEGATED
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  UNITS_OF_PRODUCTION
  SUM_OF_YEARS_DIGITS
}

enum DepreciationRunStatus {
  POSTED
  REVERSED
}

enum CostMethod {
  FIFO
  WEIGHTED_AVERAGE
  STANDARD
}

enum BudgetType {
  ORIGINAL
  REVISED
  ROLLING_FORECAST
}

enum CostCentreLevel {
  COMPANY
  DIVISION
  DEPARTMENT
  TEAM
}

enum CommitmentType {
  PURCHASE_ORDER
  REQUISITION
  CONTRACT
}

enum CommitmentStatus {
  OPEN
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CANCELLED
}

enum TaxTreatment {
  STANDARD
  ZERO_RATED
  EXEMPT
  REVERSE_CHARGE
  IMPORT_VAT
  WITHHOLDING
}

enum ExchangeRateType {
  SPOT
  MONTHLY_AVERAGE
  PERIOD_CLOSING
}

enum VatReturnStatus {
  DRAFT
  SUBMITTED
  FILED
}

enum FxRevaluationStatus {
  POSTED
  REVERSED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
}

enum PayFrequency {
  MONTHLY
  FORTNIGHTLY
  WEEKLY
}

enum SalaryComponentType {
  BASIC_SALARY
  OVERTIME
  BONUS
  COMMISSION
  ALLOWANCE
  OTHER_EARNING
  EMPLOYEE_DEDUCTION
  EMPLOYER_CONTRIBUTION
}

enum PayrollRunStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  LOCKED
}

enum PayslipStatus {
  DRAFT
  FINALISED
  PAID
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum OvertimeType {
  NONE
  FIXED
  RATE_BASED
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  STOCKTAKE_IN
  STOCKTAKE_OUT
  OPENING
}

enum MovementStatus {
  PENDING
  APPROVED
  POSTED
  REJECTED
}

enum StocktakeStatus {
  OPEN
  COUNTING
  REVIEWING
  POSTED
  CANCELLED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  DISPOSED
  FULLY_DEPRECIATED
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSED
  CANCELLED
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  firstName            String
  lastName             String
  jobTitle             String?
  isActive             Boolean   @default(true)
  isSuperAdmin         Boolean   @default(false)
  mustChangePassword   Boolean   @default(false)
  failedLoginAttempts  Int       @default(0)
  lockedAt             DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organisationUsers   OrganisationUser[]
  refreshTokens       RefreshToken[]
  createdJournals     JournalEntry[]      @relation("JournalCreatedBy")
  approvedJournals    JournalEntry[]      @relation("JournalApprovedBy")
  postedJournals      JournalEntry[]      @relation("JournalPostedBy")
  approvalDecisions   ApprovalDecision[]
  approvalRequests    ApprovalRequest[]   @relation("ApprovalRequestedBy")
  approvalLevelUsers  ApprovalLevelUser[]
  delegationsFrom     ApprovalDelegation[] @relation("DelegationFrom")
  delegationsTo       ApprovalDelegation[] @relation("DelegationTo")
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ============================================================
// ORGANISATION
// ============================================================

model Organisation {
  id                  String   @id @default(uuid())
  name                String
  legalName           String?
  registrationNo      String?
  taxId               String?
  vatRegistrationNo   String?
  baseCurrency        String   @default("USD")
  fiscalYearStart     Int      @default(1)
  address         Json?
  phone           String?
  email           String?
  website         String?
  logo            String?
  industry        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organisationUsers  OrganisationUser[]
  accounts           Account[]
  accountingPeriods  AccountingPeriod[]
  journalEntries     JournalEntry[]
  ledgerEntries      LedgerEntry[]
  approvalWorkflows  ApprovalWorkflow[]
  auditLogs          AuditLog[]
  customers          Customer[]
  suppliers          Supplier[]
  fixedAssets        FixedAsset[]
  assetCategories    AssetCategory[]
  depreciationRuns   DepreciationRun[]
  assetRevaluations  AssetRevaluation[]
  assetImpairments   AssetImpairment[]
  bankAccounts       BankAccount[]
  inventoryItems       InventoryItem[]
  inventoryCategories  InventoryCategory[]
  inventoryLocations   InventoryLocation[]
  stockBalances        StockBalance[]
  inventoryMovements   InventoryMovement[]
  inventoryLots        InventoryLot[]
  stocktakeSessions    StocktakeSession[]
  budgets              Budget[]
  costCentres          CostCentre[]
  departments          Department[]
  budgetCommitments    BudgetCommitment[]
  taxCodes                TaxCode[]
  exchangeRates           ExchangeRate[]
  vatReturns              VatReturn[]
  fxRevaluations          FxRevaluation[]
  employees               Employee[]
  salaryComponents        SalaryComponent[]
  payrollRuns             PayrollRun[]
  payslips                Payslip[]
  payrollStatutoryConfigs PayrollStatutoryConfig[]
  employeeLoans           EmployeeLoan[]
  invoices                Invoice[]
  supplierInvoices        SupplierInvoice[]
  supplierPayments        SupplierPayment[]
  supplierCreditNotes     SupplierCreditNote[]
  approvalDelegations     ApprovalDelegation[]
  notifications           Notification[]

  @@map("organisations")
}

model OrganisationUser {
  id             String    @id @default(uuid())
  organisationId String
  userId         String
  role           UserRole
  isActive       Boolean   @default(true)
  invitedAt      DateTime  @default(now())
  joinedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
  @@index([organisationId])
  @@index([userId])
  @@map("organisation_users")
}

// ============================================================
// CHART OF ACCOUNTS
// ============================================================

model Account {
  id               String       @id @default(uuid())
  organisationId   String
  code             String
  name             String
  description      String?
  class            AccountClass
  subClass         String?
  type             AccountType
  parentId         String?
  isControlAccount Boolean      @default(false)
  isBankAccount    Boolean      @default(false)
  currency         String?
  taxRate          Decimal?     @db.Decimal(5, 2)
  isActive         Boolean      @default(true)
  isLocked         Boolean      @default(false)
  isDeleted        Boolean      @default(false)
  level            Int          @default(1)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organisation  Organisation @relation(fields: [organisationId], references: [id])
  parent        Account?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]    @relation("AccountHierarchy")
  journalLines  JournalLine[]
  ledgerEntries LedgerEntry[]
  budgetLines        BudgetLine[]
  budgetCommitments  BudgetCommitment[]
  bankAccount        BankAccount?
  taxCodes             TaxCode[]           @relation("TaxGLAccount")
  fxRevaluationLines   FxRevaluationLine[]
  salaryComponents     SalaryComponent[]   @relation("ComponentGLAccount")
  employeeExpenses     Employee[]          @relation("EmployeeSalaryExpense")
  employeeLoans        EmployeeLoan[]      @relation("LoanGLAccount")

  @@unique([organisationId, code])
  @@index([organisationId, class])
  @@index([organisationId, isActive])
  @@index([parentId])
  @@map("accounts")
}

// ============================================================
// ACCOUNTING PERIODS
// ============================================================

model AccountingPeriod {
  id             String       @id @default(uuid())
  organisationId String
  name           String
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  fiscalYear     Int
  periodNumber   Int
  status         PeriodStatus @default(OPEN)
  closedBy       String?
  closedAt       DateTime?

  organisation   Organisation   @relation(fields: [organisationId], references: [id])
  journalEntries JournalEntry[]
  ledgerEntries  LedgerEntry[]
  payrollRuns    PayrollRun[]

  @@unique([organisationId, fiscalYear, periodNumber])
  @@index([organisationId, status])
  @@index([organisationId, fiscalYear])
  @@map("accounting_periods")
}

// ============================================================
// JOURNAL ENTRIES (Core Accounting Engine)
// ============================================================

model JournalEntry {
  id                 String      @id @default(uuid())
  organisationId     String
  journalNumber      String
  type               JournalType
  reference          String?
  description        String
  entryDate          DateTime    @db.Date
  postingDate        DateTime    @db.Date
  periodId           String
  currency           String
  exchangeRate       Decimal     @default(1) @db.Decimal(20, 6)
  status             EntryStatus @default(DRAFT)
  approvalWorkflowId String?
  approvedBy         String?
  approvedAt         DateTime?
  postedBy           String?
  postedAt           DateTime?
  reversedByEntryId  String?     @unique
  isSystemGenerated  Boolean     @default(false)
  createdBy          String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  organisation     Organisation      @relation(fields: [organisationId], references: [id])
  period           AccountingPeriod  @relation(fields: [periodId], references: [id])
  creator          User              @relation("JournalCreatedBy", fields: [createdBy], references: [id])
  approver         User?             @relation("JournalApprovedBy", fields: [approvedBy], references: [id])
  poster           User?             @relation("JournalPostedBy", fields: [postedBy], references: [id])
  approvalWorkflow ApprovalWorkflow? @relation(fields: [approvalWorkflowId], references: [id])
  lines            JournalLine[]
  ledgerEntries    LedgerEntry[]
  approvalRequests ApprovalRequest[]
  reversalOf       JournalEntry?     @relation("JournalReversal")
  reversedBy       JournalEntry?     @relation("JournalReversal", fields: [reversedByEntryId], references: [id])

  @@unique([organisationId, journalNumber])
  @@index([organisationId, entryDate, status])
  @@index([organisationId, type])
  @@index([organisationId, status])
  @@index([periodId])
  @@map("journal_entries")
}

model JournalLine {
  id               String  @id @default(uuid())
  journalEntryId   String
  lineNumber       Int
  accountId        String
  description      String?
  debitAmount      Decimal @default(0) @db.Decimal(20, 4)
  creditAmount     Decimal @default(0) @db.Decimal(20, 4)
  currency         String
  exchangeRate     Decimal @default(1) @db.Decimal(20, 6)
  baseDebitAmount  Decimal @default(0) @db.Decimal(20, 4)
  baseCreditAmount Decimal @default(0) @db.Decimal(20, 4)
  taxCode          String?
  taxAmount        Decimal? @db.Decimal(20, 4)
  costCentreId     String?
  projectId        String?
  departmentId     String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  costCentre   CostCentre?  @relation(fields: [costCentreId], references: [id])
  department     Department?     @relation(fields: [departmentId], references: [id])
  ledgerEntry    LedgerEntry?
  vatReturnLines VatReturnLine[]

  @@index([journalEntryId])
  @@index([accountId, journalEntryId])
  @@map("journal_lines")
}

// ============================================================
// GENERAL LEDGER
// ============================================================

model LedgerEntry {
  id              String   @id @default(uuid())
  organisationId  String
  accountId       String
  journalEntryId  String
  journalLineId   String   @unique
  transactionDate DateTime @db.Date
  postingDate     DateTime @db.Date
  description     String?
  debitAmount     Decimal  @default(0) @db.Decimal(20, 4)
  creditAmount    Decimal  @default(0) @db.Decimal(20, 4)
  runningBalance  Decimal  @db.Decimal(20, 4)
  periodId        String

  organisation Organisation     @relation(fields: [organisationId], references: [id])
  account      Account          @relation(fields: [accountId], references: [id])
  journalEntry JournalEntry     @relation(fields: [journalEntryId], references: [id])
  journalLine  JournalLine      @relation(fields: [journalLineId], references: [id])
  period       AccountingPeriod @relation(fields: [periodId], references: [id])

  @@index([accountId, postingDate])
  @@index([organisationId, periodId])
  @@index([journalEntryId])
  @@map("ledger_entries")
}

// ============================================================
// APPROVAL WORKFLOW
// ============================================================

model ApprovalWorkflow {
  id             String             @id @default(uuid())
  organisationId String
  name           String
  description    String?
  entityType     ApprovalEntityType
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organisation   Organisation      @relation(fields: [organisationId], references: [id])
  levels         ApprovalLevel[]
  journalEntries JournalEntry[]
  requests       ApprovalRequest[]

  @@index([organisationId, entityType])
  @@map("approval_workflows")
}

model ApprovalLevel {
  id                 String       @id @default(uuid())
  workflowId         String
  levelNumber        Int
  name               String
  approvalType       ApprovalType
  amountThresholdMin Decimal?     @db.Decimal(20, 4)
  amountThresholdMax Decimal?     @db.Decimal(20, 4)
  escalationHours    Int?
  escalateTo         String?

  workflow  ApprovalWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approvers ApprovalLevelUser[]

  @@unique([workflowId, levelNumber])
  @@map("approval_levels")
}

model ApprovalLevelUser {
  id      String @id @default(uuid())
  levelId String
  userId  String

  level ApprovalLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id])

  @@unique([levelId, userId])
  @@map("approval_level_users")
}

model ApprovalRequest {
  id           String                @id @default(uuid())
  workflowId   String
  entityType   ApprovalEntityType
  entityId     String
  requestedBy  String
  requestedAt  DateTime              @default(now())
  status       ApprovalRequestStatus @default(PENDING)
  currentLevel Int                   @default(1)
  comments     String?
  completedAt  DateTime?
  slaDeadline  DateTime?
  escalatedAt  DateTime?

  workflow  ApprovalWorkflow   @relation(fields: [workflowId], references: [id])
  requester User               @relation("ApprovalRequestedBy", fields: [requestedBy], references: [id])
  decisions ApprovalDecision[]
  journal   JournalEntry?      @relation(fields: [entityId], references: [id])

  @@index([entityType, entityId])
  @@index([workflowId, status])
  @@map("approval_requests")
}

model ApprovalDecision {
  id                String               @id @default(uuid())
  approvalRequestId String
  levelNumber       Int
  decidedBy         String
  decision          ApprovalDecisionType
  comments          String?
  decidedAt         DateTime             @default(now())
  delegatedTo       String?

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  decider         User            @relation(fields: [decidedBy], references: [id])

  @@index([approvalRequestId])
  @@map("approval_decisions")
}

model ApprovalDelegation {
  id             String   @id @default(uuid())
  organisationId String
  workflowId     String?
  delegatedBy    String
  delegatedTo    String
  validFrom      DateTime @db.Date
  validTo        DateTime @db.Date
  isActive       Boolean  @default(true)
  reason         String?
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  delegator    User         @relation("DelegationFrom", fields: [delegatedBy], references: [id])
  delegatee    User         @relation("DelegationTo",   fields: [delegatedTo], references: [id])

  @@index([organisationId, isActive])
  @@index([delegatedTo, isActive])
  @@map("approval_delegations")
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  organisationId String
  type           NotificationType
  title          String
  body           String
  entityId       String?
  entityType     String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@index([userId, isRead])
  @@index([organisationId])
  @@map("notifications")
}

// ============================================================
// AUDIT LOG (append-only — enforced at application layer)
// ============================================================

model AuditLog {
  id             String   @id @default(uuid())
  organisationId String?
  userId         String?
  action         String
  module         String?
  entityType     String
  entityId       String?
  entityRef      String?
  description    String?
  previousValue  Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organisationId, timestamp])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([module])
  @@map("audit_logs")
}

// ============================================================
// ACCOUNTS RECEIVABLE
// ============================================================

model Customer {
  id             String   @id @default(uuid())
  organisationId String
  code           String
  name           String
  email          String?
  phone          String?
  address        Json?
  taxId          String?
  creditLimit    Decimal? @db.Decimal(20, 4)
  paymentTerms   Int      @default(30)
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  invoices     Invoice[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("customers")
}

model Invoice {
  id             String        @id @default(uuid())
  organisationId String
  customerId     String
  invoiceNumber  String
  invoiceDate    DateTime      @db.Date
  dueDate        DateTime      @db.Date
  currency       String
  exchangeRate   Decimal       @default(1) @db.Decimal(20, 6)
  subtotal       Decimal       @db.Decimal(20, 4)
  taxAmount      Decimal       @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal       @db.Decimal(20, 4)
  amountPaid     Decimal       @default(0) @db.Decimal(20, 4)
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  journalEntryId String?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lines        InvoiceLine[]

  @@unique([organisationId, invoiceNumber])
  @@index([organisationId, status])
  @@index([customerId])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  lineNumber  Int
  description String
  quantity    Decimal @db.Decimal(20, 4)
  unitPrice   Decimal @db.Decimal(20, 4)
  taxCode     String?
  taxAmount   Decimal @default(0) @db.Decimal(20, 4)
  lineTotal   Decimal @db.Decimal(20, 4)
  accountId   String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ============================================================
// ACCOUNTS PAYABLE
// ============================================================

model Supplier {
  id             String   @id @default(uuid())
  organisationId String
  code           String
  name           String
  email          String?
  phone          String?
  address        Json?
  taxId          String?
  paymentTerms      Int      @default(30)
  bankDetails       Json?
  whtRate           Decimal? @db.Decimal(5, 2)
  whtClassification String?
  isActive          Boolean  @default(true)
  isDeleted         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organisation        Organisation         @relation(fields: [organisationId], references: [id])
  supplierInvoices    SupplierInvoice[]
  supplierPayments    SupplierPayment[]
  supplierCreditNotes SupplierCreditNote[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("suppliers")
}

model SupplierInvoice {
  id             String        @id @default(uuid())
  organisationId String
  supplierId     String
  invoiceNumber  String
  supplierRef    String?
  invoiceDate    DateTime      @db.Date
  dueDate        DateTime      @db.Date
  currency       String
  exchangeRate   Decimal       @default(1) @db.Decimal(20, 6)
  subtotal       Decimal       @db.Decimal(20, 4)
  taxAmount      Decimal       @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal       @db.Decimal(20, 4)
  amountPaid     Decimal       @default(0) @db.Decimal(20, 4)
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  journalEntryId String?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organisation        Organisation         @relation(fields: [organisationId], references: [id])
  supplier            Supplier             @relation(fields: [supplierId], references: [id])
  lines               SupplierInvoiceLine[]
  supplierPayments    SupplierPayment[]
  supplierCreditNotes SupplierCreditNote[]

  @@unique([organisationId, invoiceNumber])
  @@index([organisationId, status])
  @@index([supplierId])
  @@map("supplier_invoices")
}

model SupplierInvoiceLine {
  id               String  @id @default(uuid())
  supplierInvoiceId String
  lineNumber       Int
  description      String
  quantity         Decimal @db.Decimal(20, 4)
  unitPrice        Decimal @db.Decimal(20, 4)
  taxCode          String?
  taxAmount        Decimal @default(0) @db.Decimal(20, 4)
  lineTotal        Decimal @db.Decimal(20, 4)
  accountId        String?

  supplierInvoice SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  @@index([supplierInvoiceId])
  @@map("supplier_invoice_lines")
}

model SupplierPayment {
  id                String    @id @default(uuid())
  organisationId    String
  supplierInvoiceId String
  supplierId        String
  paymentDate       DateTime  @db.Date
  amount            Decimal   @db.Decimal(20, 4)
  whtAmount         Decimal   @default(0) @db.Decimal(20, 4)
  whtRate           Decimal?  @db.Decimal(5, 2)
  reference         String?
  bankAccountId     String
  periodId          String
  journalEntryId    String?
  isReversed        Boolean   @default(false)
  reversedAt        DateTime?
  reversedBy        String?
  reversalReason    String?
  reversalJournalId String?
  createdBy         String
  createdAt         DateTime  @default(now())

  organisation Organisation    @relation(fields: [organisationId], references: [id])
  invoice      SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id])
  supplier     Supplier        @relation(fields: [supplierId], references: [id])

  @@index([organisationId])
  @@index([supplierInvoiceId])
  @@map("supplier_payments")
}

model SupplierCreditNote {
  id                String    @id @default(uuid())
  organisationId    String
  supplierId        String
  supplierInvoiceId String?
  creditNoteNumber  String
  creditNoteDate    DateTime  @db.Date
  amount            Decimal   @db.Decimal(20, 4)
  taxAmount         Decimal   @default(0) @db.Decimal(20, 4)
  reason            String?
  currency          String    @default("GHS")
  exchangeRate      Decimal   @default(1) @db.Decimal(20, 6)
  journalEntryId    String?
  createdBy         String
  createdAt         DateTime  @default(now())

  organisation Organisation     @relation(fields: [organisationId], references: [id])
  supplier     Supplier         @relation(fields: [supplierId], references: [id])
  invoice      SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])

  @@index([organisationId])
  @@index([supplierId])
  @@map("supplier_credit_notes")
}

// ============================================================
// FIXED ASSETS (IAS 16, IAS 38)
// ============================================================

model FixedAsset {
  id                        String             @id @default(uuid())
  organisationId            String
  code                      String
  name                      String
  description               String?
  category                  String
  categoryId                String?
  serialNumber              String?
  location                  String?
  acquisitionDate           DateTime           @db.Date
  acquisitionCost           Decimal            @db.Decimal(20, 4)
  residualValue             Decimal            @default(0) @db.Decimal(20, 4)
  usefulLifeMonths          Int
  depreciationMethod        DepreciationMethod @default(STRAIGHT_LINE)
  unitsOfProductionTotal    Int?
  depreciationMonthsElapsed Int                @default(0)
  accumulatedDeprn          Decimal            @default(0) @db.Decimal(20, 4)
  impairmentLoss            Decimal            @default(0) @db.Decimal(20, 4)
  carryingValue             Decimal            @db.Decimal(20, 4)
  status                    AssetStatus        @default(ACTIVE)
  disposalDate              DateTime?          @db.Date
  disposalProceeds          Decimal?           @db.Decimal(20, 4)
  reducingBalanceRate       Decimal?           @db.Decimal(8, 6)
  assetAccountId            String?
  deprnAccountId            String?
  accDeprnAccountId         String?
  lastDeprnDate             DateTime?          @db.Date
  isDeleted                 Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organisation     Organisation          @relation(fields: [organisationId], references: [id])
  assetCategory    AssetCategory?        @relation(fields: [categoryId], references: [id])
  revaluations     AssetRevaluation[]
  impairments      AssetImpairment[]
  deprnRunEntries  DepreciationRunEntry[]

  @@unique([organisationId, code])
  @@index([organisationId, status])
  @@map("fixed_assets")
}

model AssetCategory {
  id                        String             @id @default(uuid())
  organisationId            String
  code                      String
  name                      String
  description               String?
  defaultDepreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  defaultUsefulLifeMonths   Int?
  capitalisationThreshold   Decimal?           @db.Decimal(20, 4)
  // GL accounts applied to all assets in this category by default
  assetCostAccountId                String?
  depreciationExpenseAccountId      String?
  accumulatedDepreciationAccountId  String?
  gainLossOnDisposalAccountId       String?
  isActive                  Boolean            @default(true)
  isDeleted                 Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  assets       FixedAsset[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("asset_categories")
}

model AssetRevaluation {
  id                    String       @id @default(uuid())
  organisationId        String
  assetId               String
  revaluationDate       DateTime     @db.Date
  fairValue             Decimal      @db.Decimal(20, 4)
  previousCarryingValue Decimal      @db.Decimal(20, 4)
  surplusDeficit        Decimal      @db.Decimal(20, 4)
  journalEntryId        String?
  notes                 String?
  createdBy             String
  createdAt             DateTime     @default(now())

  asset        FixedAsset   @relation(fields: [assetId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@index([assetId])
  @@index([organisationId])
  @@map("asset_revaluations")
}

model AssetImpairment {
  id                    String   @id @default(uuid())
  organisationId        String
  assetId               String
  impairmentDate        DateTime @db.Date
  impairmentAmount      Decimal  @db.Decimal(20, 4)
  previousCarryingValue Decimal  @db.Decimal(20, 4)
  newCarryingValue      Decimal  @db.Decimal(20, 4)
  journalEntryId        String?
  notes                 String?
  createdBy             String
  createdAt             DateTime @default(now())

  asset        FixedAsset   @relation(fields: [assetId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@index([assetId])
  @@index([organisationId])
  @@map("asset_impairments")
}

model DepreciationRun {
  id             String                @id @default(uuid())
  organisationId String
  periodId       String
  asOfDate       DateTime              @db.Date
  processedCount Int
  totalAmount    Decimal               @db.Decimal(20, 4)
  status         DepreciationRunStatus @default(POSTED)
  reversedAt     DateTime?
  reversedBy     String?
  createdBy      String
  createdAt      DateTime              @default(now())

  organisation Organisation          @relation(fields: [organisationId], references: [id])
  entries      DepreciationRunEntry[]

  @@index([organisationId])
  @@map("depreciation_runs")
}

model DepreciationRunEntry {
  id             String @id @default(uuid())
  runId          String
  assetId        String
  amount         Decimal @db.Decimal(20, 4)
  journalEntryId String

  run   DepreciationRun @relation(fields: [runId], references: [id])
  asset FixedAsset      @relation(fields: [assetId], references: [id])

  @@index([runId])
  @@map("depreciation_run_entries")
}

// ============================================================
// BANK RECONCILIATION
// ============================================================

model BankAccount {
  id             String   @id @default(uuid())
  organisationId String
  accountId      String   @unique
  bankName       String
  accountNumber  String
  branchCode     String?
  currency       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation   Organisation    @relation(fields: [organisationId], references: [id])
  account        Account         @relation(fields: [accountId], references: [id])
  bankStatements BankStatement[]

  @@index([organisationId])
  @@map("bank_accounts")
}

model BankStatement {
  id             String    @id @default(uuid())
  bankAccountId  String
  statementDate  DateTime  @db.Date
  openingBalance Decimal   @db.Decimal(20, 4)
  closingBalance Decimal   @db.Decimal(20, 4)
  isReconciled   Boolean   @default(false)
  isLocked       Boolean   @default(false)
  reconciledAt   DateTime?
  reconciledBy   String?
  createdAt      DateTime  @default(now())

  bankAccount BankAccount        @relation(fields: [bankAccountId], references: [id])
  lines       BankStatementLine[]

  @@index([bankAccountId])
  @@map("bank_statements")
}

model BankStatementLine {
  id             String   @id @default(uuid())
  statementId    String
  transactionDate DateTime @db.Date
  description    String
  debitAmount    Decimal  @default(0) @db.Decimal(20, 4)
  creditAmount   Decimal  @default(0) @db.Decimal(20, 4)
  reference      String?
  isMatched      Boolean  @default(false)
  matchedEntryId String?
  matchNote      String?
  journalEntryId String?

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId, isMatched])
  @@map("bank_statement_lines")
}

// ============================================================
// INVENTORY (IAS 2)
// ============================================================

model InventoryItem {
  id                 String     @id @default(uuid())
  organisationId     String
  code               String
  name               String
  description        String?
  category           String?
  categoryId         String?
  unit               String     @default("unit")
  costMethod         CostMethod @default(WEIGHTED_AVERAGE)
  unitCost           Decimal    @default(0) @db.Decimal(20, 4)
  standardCost       Decimal?   @db.Decimal(20, 4)
  quantityOnHand     Decimal    @default(0) @db.Decimal(20, 4)
  reorderLevel       Decimal?   @db.Decimal(20, 4)
  reorderQuantity    Decimal?   @db.Decimal(20, 4)
  inventoryAccountId String?
  cogsAccountId      String?
  isActive           Boolean    @default(true)
  isDeleted          Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  organisation      Organisation       @relation(fields: [organisationId], references: [id])
  inventoryCategory InventoryCategory? @relation(fields: [categoryId], references: [id])
  movements         InventoryMovement[]
  lots              InventoryLot[]
  stockBalances     StockBalance[]
  stocktakeCounts   StocktakeCount[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("inventory_items")
}

model InventoryCategory {
  id             String   @id @default(uuid())
  organisationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organisation Organisation  @relation(fields: [organisationId], references: [id])
  items        InventoryItem[]

  @@unique([organisationId, name])
  @@index([organisationId])
  @@map("inventory_categories")
}

model InventoryLocation {
  id             String   @id @default(uuid())
  organisationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organisation      Organisation       @relation(fields: [organisationId], references: [id])
  movements         InventoryMovement[]
  stockBalances     StockBalance[]
  stocktakeSessions StocktakeSession[]
  stocktakeCounts   StocktakeCount[]

  @@unique([organisationId, name])
  @@index([organisationId])
  @@map("inventory_locations")
}

model StockBalance {
  id             String   @id @default(uuid())
  organisationId String
  itemId         String
  locationId     String?
  quantityOnHand Decimal  @default(0) @db.Decimal(20, 4)
  averageCost    Decimal  @default(0) @db.Decimal(20, 4)
  totalValue     Decimal  @default(0) @db.Decimal(20, 4)
  updatedAt      DateTime @updatedAt

  organisation Organisation       @relation(fields: [organisationId], references: [id])
  item         InventoryItem      @relation(fields: [itemId], references: [id])
  location     InventoryLocation? @relation(fields: [locationId], references: [id])

  @@unique([itemId, locationId])
  @@index([organisationId])
  @@map("stock_balances")
}

model InventoryMovement {
  id              String        @id @default(uuid())
  organisationId  String
  itemId          String
  locationId      String?
  movementType    MovementType
  quantity        Decimal       @db.Decimal(20, 4)
  unitCost        Decimal       @default(0) @db.Decimal(20, 4)
  totalCost       Decimal       @default(0) @db.Decimal(20, 4)
  contraAccountId String?
  reference       String?
  description     String?
  reasonCode      String?
  status          MovementStatus @default(PENDING)
  journalEntryId  String?
  periodId        String?
  transactionDate DateTime      @db.Date
  requestedBy     String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())

  organisation Organisation       @relation(fields: [organisationId], references: [id])
  item         InventoryItem      @relation(fields: [itemId], references: [id])
  location     InventoryLocation? @relation(fields: [locationId], references: [id])

  @@index([organisationId, itemId])
  @@index([organisationId, transactionDate])
  @@index([organisationId, status])
  @@map("inventory_movements")
}

model InventoryLot {
  id                String   @id @default(uuid())
  organisationId    String
  itemId            String
  locationId        String?
  receivedDate      DateTime @db.Date
  originalQuantity  Decimal  @db.Decimal(20, 4)
  remainingQuantity Decimal  @db.Decimal(20, 4)
  unitCost          Decimal  @db.Decimal(20, 4)
  reference         String?
  movementId        String?
  isClosed          Boolean  @default(false)
  createdAt         DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  item         InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId, isClosed, receivedDate])
  @@index([organisationId])
  @@map("inventory_lots")
}

model StocktakeSession {
  id             String          @id @default(uuid())
  organisationId String
  locationId     String?
  name           String
  sessionDate    DateTime        @db.Date
  status         StocktakeStatus @default(OPEN)
  notes          String?
  createdBy      String
  postedBy       String?
  postedAt       DateTime?
  createdAt      DateTime        @default(now())

  organisation Organisation       @relation(fields: [organisationId], references: [id])
  location     InventoryLocation? @relation(fields: [locationId], references: [id])
  counts       StocktakeCount[]

  @@index([organisationId])
  @@map("stocktake_sessions")
}

model StocktakeCount {
  id               String   @id @default(uuid())
  sessionId        String
  itemId           String
  locationId       String?
  systemQuantity   Decimal  @db.Decimal(20, 4)
  countedQuantity  Decimal? @db.Decimal(20, 4)
  varianceQuantity Decimal? @db.Decimal(20, 4)
  unitCost         Decimal  @default(0) @db.Decimal(20, 4)
  varianceValue    Decimal? @db.Decimal(20, 4)
  notes            String?

  session  StocktakeSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item     InventoryItem      @relation(fields: [itemId], references: [id])
  location InventoryLocation? @relation(fields: [locationId], references: [id])

  @@unique([sessionId, itemId])
  @@index([sessionId])
  @@map("stocktake_counts")
}

// ============================================================
// BUDGETS
// ============================================================

model Budget {
  id                String     @id @default(uuid())
  organisationId    String
  name              String
  fiscalYear        Int
  budgetType        BudgetType @default(ORIGINAL)
  version           Int        @default(1)
  parentBudgetId    String?
  alertThresholdPct Decimal?   @db.Decimal(5, 2)
  isApproved        Boolean    @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  organisation Organisation      @relation(fields: [organisationId], references: [id])
  parentBudget Budget?           @relation("BudgetRevisions", fields: [parentBudgetId], references: [id])
  revisions    Budget[]          @relation("BudgetRevisions")
  lines        BudgetLine[]
  commitments  BudgetCommitment[]

  @@unique([organisationId, fiscalYear, name, version])
  @@index([organisationId])
  @@map("budgets")
}

model BudgetLine {
  id           String  @id @default(uuid())
  budgetId     String
  accountId    String
  costCentreId String?
  periodNumber Int
  amount       Decimal @db.Decimal(20, 4)

  budget     Budget      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account    Account     @relation(fields: [accountId], references: [id])
  costCentre CostCentre? @relation(fields: [costCentreId], references: [id])

  @@unique([budgetId, accountId, costCentreId, periodNumber])
  @@index([budgetId])
  @@map("budget_lines")
}

// ============================================================
// COST CENTRES & DEPARTMENTS
// ============================================================

model CostCentre {
  id                  String          @id @default(uuid())
  organisationId      String
  code                String
  name                String
  description         String?
  level               CostCentreLevel @default(DEPARTMENT)
  parentId            String?
  isReportableSegment Boolean         @default(false)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organisation  Organisation       @relation(fields: [organisationId], references: [id])
  parent        CostCentre?        @relation("CostCentreHierarchy", fields: [parentId], references: [id])
  children      CostCentre[]       @relation("CostCentreHierarchy")
  journalLines  JournalLine[]
  budgetLines   BudgetLine[]
  commitments   BudgetCommitment[]
  employees     Employee[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("cost_centres")
}

model Department {
  id             String   @id @default(uuid())
  organisationId String
  code           String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  journalLines JournalLine[]
  employees    Employee[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("departments")
}

model BudgetCommitment {
  id              String           @id @default(uuid())
  organisationId  String
  budgetId        String
  accountId       String
  costCentreId    String?
  periodNumber    Int
  amount          Decimal          @db.Decimal(20, 4)
  invoicedAmount  Decimal          @default(0) @db.Decimal(20, 4)
  referenceType   CommitmentType
  reference       String?
  description     String?
  status          CommitmentStatus @default(OPEN)
  raisedDate      DateTime         @db.Date
  raisedBy        String?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  budget       Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  costCentre   CostCentre?  @relation(fields: [costCentreId], references: [id])

  @@index([organisationId, budgetId])
  @@index([organisationId, status])
  @@map("budget_commitments")
}

// ============================================================
// TAX
// ============================================================

model TaxCode {
  id             String       @id @default(uuid())
  organisationId String
  code           String
  name           String
  treatment      TaxTreatment @default(STANDARD)
  rate           Decimal      @db.Decimal(5, 2)
  isInclusive    Boolean      @default(false)
  glAccountId    String?
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  glAccount    Account?     @relation("TaxGLAccount", fields: [glAccountId], references: [id])

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("tax_codes")
}

// ============================================================
// MULTI-CURRENCY (IAS 21)
// ============================================================

model ExchangeRate {
  id             String           @id @default(uuid())
  organisationId String
  fromCurrency   String
  toCurrency     String
  rate           Decimal          @db.Decimal(20, 6)
  rateType       ExchangeRateType @default(SPOT)
  effectiveDate  DateTime         @db.Date
  createdAt      DateTime         @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@index([organisationId, effectiveDate])
  @@index([fromCurrency, toCurrency, effectiveDate])
  @@map("exchange_rates")
}

// ============================================================
// VAT RETURN
// ============================================================

model VatReturn {
  id                 String          @id @default(uuid())
  organisationId     String
  periodStart        DateTime        @db.Date
  periodEnd          DateTime        @db.Date
  status             VatReturnStatus @default(DRAFT)
  box1OutputTax      Decimal         @default(0) @db.Decimal(20, 4)
  box2AcquisitionTax Decimal         @default(0) @db.Decimal(20, 4)
  box3TotalOutput    Decimal         @default(0) @db.Decimal(20, 4)
  box4InputTax       Decimal         @default(0) @db.Decimal(20, 4)
  box5NetVat         Decimal         @default(0) @db.Decimal(20, 4)
  box6TotalSupplies  Decimal         @default(0) @db.Decimal(20, 4)
  box7TotalPurchases Decimal         @default(0) @db.Decimal(20, 4)
  generatedBy        String?
  submittedAt        DateTime?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organisation Organisation   @relation(fields: [organisationId], references: [id])
  lines        VatReturnLine[]

  @@index([organisationId, periodStart])
  @@map("vat_returns")
}

model VatReturnLine {
  id            String   @id @default(uuid())
  vatReturnId   String
  boxNumber     Int
  journalLineId String?
  netAmount     Decimal  @db.Decimal(20, 4)
  taxAmount     Decimal  @db.Decimal(20, 4)
  taxCode       String?
  description   String?
  entryDate     DateTime @db.Date
  reference     String?

  vatReturn   VatReturn    @relation(fields: [vatReturnId], references: [id], onDelete: Cascade)
  journalLine JournalLine? @relation(fields: [journalLineId], references: [id])

  @@index([vatReturnId])
  @@map("vat_return_lines")
}

// ============================================================
// FX REVALUATION (IAS 21)
// ============================================================

model FxRevaluation {
  id                     String              @id @default(uuid())
  organisationId         String
  periodEndDate          DateTime            @db.Date
  status                 FxRevaluationStatus @default(POSTED)
  journalEntryId         String?
  reversalJournalEntryId String?
  generatedBy            String?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organisation Organisation        @relation(fields: [organisationId], references: [id])
  lines        FxRevaluationLine[]

  @@index([organisationId, periodEndDate])
  @@map("fx_revaluations")
}

model FxRevaluationLine {
  id             String  @id @default(uuid())
  revaluationId  String
  accountId      String
  currency       String
  openingBalance Decimal @db.Decimal(20, 4)
  originalRate   Decimal @db.Decimal(20, 6)
  closingRate    Decimal @db.Decimal(20, 6)
  baseBefore     Decimal @db.Decimal(20, 4)
  baseAfter      Decimal @db.Decimal(20, 4)
  gainLoss       Decimal @db.Decimal(20, 4)

  revaluation FxRevaluation @relation(fields: [revaluationId], references: [id], onDelete: Cascade)
  account     Account       @relation(fields: [accountId], references: [id])

  @@index([revaluationId])
  @@map("fx_revaluation_lines")
}

// ============================================================
// PAYROLL
// ============================================================

model PayrollStatutoryConfig {
  id                String   @id @default(uuid())
  organisationId    String
  taxYear           Int
  // SSNIT rates (as decimals: 0.055 = 5.5%)
  ssnitEmployeeRate Decimal  @default(0.055)  @db.Decimal(6, 4)
  ssnitEmployerRate Decimal  @default(0.13)   @db.Decimal(6, 4)
  tier2Rate         Decimal  @default(0.05)   @db.Decimal(6, 4)
  // PAYE bands — JSON array: [{min, max, rate}] monthly GHS amounts, rate as percent
  payeBands         Json
  // Monthly personal relief (deducted before PAYE)
  personalRelief    Decimal  @default(0)      @db.Decimal(20, 4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@unique([organisationId, taxYear])
  @@index([organisationId])
  @@map("payroll_statutory_configs")
}

model Employee {
  id                     String         @id @default(uuid())
  organisationId         String
  employeeNumber         String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  nationalId             String?
  tinNumber              String?
  ssnitNumber            String?
  employmentType         EmploymentType @default(FULL_TIME)
  payFrequency           PayFrequency   @default(MONTHLY)
  startDate              DateTime       @db.Date
  endDate                DateTime?      @db.Date
  jobTitle               String?
  departmentId           String?
  costCentreId           String?
  basicSalary            Decimal        @db.Decimal(20, 4)
  bankName               String?
  bankAccountNumber      String?
  bankBranch             String?
  tier3EmployeeRate      Decimal?       @db.Decimal(6, 4)
  tier3EmployerRate      Decimal?       @db.Decimal(6, 4)
  salaryExpenseAccountId String?
  overtimeType           String         @default("NONE")
  overtimeFixedAmount    Decimal?       @db.Decimal(20, 4)
  overtimeMultiplier     Decimal?       @db.Decimal(5, 2)
  isResident             Boolean        @default(true)
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  organisation         Organisation      @relation(fields: [organisationId], references: [id])
  department           Department?       @relation(fields: [departmentId], references: [id])
  costCentre           CostCentre?       @relation(fields: [costCentreId], references: [id])
  salaryExpenseAccount Account?          @relation("EmployeeSalaryExpense", fields: [salaryExpenseAccountId], references: [id])
  components           EmployeeComponent[]
  payslips             Payslip[]
  loans                EmployeeLoan[]

  @@unique([organisationId, employeeNumber])
  @@index([organisationId, isActive])
  @@map("employees")
}

model SalaryComponent {
  id             String              @id @default(uuid())
  organisationId String
  code           String
  name           String
  type           SalaryComponentType
  isTaxable      Boolean             @default(true)
  glAccountId    String?
  description    String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organisation       Organisation        @relation(fields: [organisationId], references: [id])
  glAccount          Account?            @relation("ComponentGLAccount", fields: [glAccountId], references: [id])
  employeeComponents EmployeeComponent[]
  payslipLines       PayslipLine[]

  @@unique([organisationId, code])
  @@index([organisationId])
  @@map("salary_components")
}

model EmployeeComponent {
  id            String    @id @default(uuid())
  employeeId    String
  componentId   String
  amount        Decimal?  @db.Decimal(20, 4)
  rate          Decimal?  @db.Decimal(8, 6)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  employee  Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  component SalaryComponent @relation(fields: [componentId], references: [id])

  @@index([employeeId])
  @@map("employee_components")
}

model PayrollRun {
  id              String           @id @default(uuid())
  organisationId  String
  runNumber       String
  periodId        String
  paymentDate     DateTime         @db.Date
  description     String
  status          PayrollRunStatus @default(DRAFT)
  isSupplementary Boolean          @default(false)
  parentRunId     String?
  // GL accounts for this run
  wagesPayableAccountId   String
  payePayableAccountId    String
  ssnitPayableAccountId   String
  pensionPayableAccountId String
  // Computed totals
  totalGross           Decimal @default(0) @db.Decimal(20, 4)
  totalPaye            Decimal @default(0) @db.Decimal(20, 4)
  totalSsnitEmployee   Decimal @default(0) @db.Decimal(20, 4)
  totalSsnitEmployer   Decimal @default(0) @db.Decimal(20, 4)
  totalTier2           Decimal @default(0) @db.Decimal(20, 4)
  totalTier3Employee   Decimal @default(0) @db.Decimal(20, 4)
  totalTier3Employer   Decimal @default(0) @db.Decimal(20, 4)
  totalOtherDeductions Decimal @default(0) @db.Decimal(20, 4)
  totalNetPay          Decimal @default(0) @db.Decimal(20, 4)
  totalEmployerCost    Decimal @default(0) @db.Decimal(20, 4)
  // Three-person workflow
  createdBy   String
  submittedBy String?
  submittedAt DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  paidBy      String?
  paidAt      DateTime?
  journalEntryId String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organisation Organisation     @relation(fields: [organisationId], references: [id])
  period       AccountingPeriod @relation(fields: [periodId], references: [id])
  parentRun    PayrollRun?      @relation("SupplementaryRun", fields: [parentRunId], references: [id])
  supplements  PayrollRun[]     @relation("SupplementaryRun")
  payslips     Payslip[]

  @@unique([organisationId, runNumber])
  @@index([organisationId, status])
  @@index([organisationId, periodId])
  @@map("payroll_runs")
}

model Payslip {
  id             String        @id @default(uuid())
  payrollRunId   String
  employeeId     String
  organisationId String
  status         PayslipStatus @default(DRAFT)
  // Earnings
  basicSalary    Decimal @default(0) @db.Decimal(20, 4)
  overtimePay    Decimal @default(0) @db.Decimal(20, 4)
  bonuses        Decimal @default(0) @db.Decimal(20, 4)
  allowances     Decimal @default(0) @db.Decimal(20, 4)
  otherEarnings  Decimal @default(0) @db.Decimal(20, 4)
  grossPay       Decimal @default(0) @db.Decimal(20, 4)
  // Employee deductions
  payeAmount      Decimal @default(0) @db.Decimal(20, 4)
  overtimeTax     Decimal @default(0) @db.Decimal(20, 4)
  bonusTax        Decimal @default(0) @db.Decimal(20, 4)
  ssnitEmployee   Decimal @default(0) @db.Decimal(20, 4)
  tier3Employee   Decimal @default(0) @db.Decimal(20, 4)
  otherDeductions Decimal @default(0) @db.Decimal(20, 4)
  totalDeductions Decimal @default(0) @db.Decimal(20, 4)
  netPay          Decimal @default(0) @db.Decimal(20, 4)
  // Employer contributions (cost, not deducted from employee)
  ssnitEmployer     Decimal @default(0) @db.Decimal(20, 4)
  tier2Employer     Decimal @default(0) @db.Decimal(20, 4)
  tier3Employer     Decimal @default(0) @db.Decimal(20, 4)
  totalEmployerCost Decimal @default(0) @db.Decimal(20, 4)
  // YTD at time of generation
  ytdGross   Decimal @default(0) @db.Decimal(20, 4)
  ytdPaye    Decimal @default(0) @db.Decimal(20, 4)
  ytdSsnit   Decimal @default(0) @db.Decimal(20, 4)
  ytdNetPay  Decimal @default(0) @db.Decimal(20, 4)
  // Snapshot of assignment at time of run
  departmentId String?
  costCentreId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payrollRun   PayrollRun   @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id])
  lines        PayslipLine[]

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payslips")
}

model PayslipLine {
  id          String              @id @default(uuid())
  payslipId   String
  componentId String?
  loanId      String?
  description String
  type        SalaryComponentType
  amount      Decimal             @db.Decimal(20, 4)
  isEmployer  Boolean             @default(false)

  payslip   Payslip          @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  component SalaryComponent? @relation(fields: [componentId], references: [id])
  loan      EmployeeLoan?    @relation(fields: [loanId], references: [id])

  @@index([payslipId])
  @@map("payslip_lines")
}

model EmployeeLoan {
  id               String     @id @default(uuid())
  organisationId   String
  employeeId       String
  description      String
  principalAmount  Decimal    @db.Decimal(20, 4)
  balance          Decimal    @db.Decimal(20, 4)
  instalmentAmount Decimal    @db.Decimal(20, 4)
  startDate        DateTime   @db.Date
  glAccountId      String?
  status           LoanStatus @default(ACTIVE)
  createdBy        String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  glAccount      Account?      @relation("LoanGLAccount", fields: [glAccountId], references: [id])
  repaymentLines PayslipLine[]

  @@index([organisationId])
  @@index([employeeId])
  @@map("employee_loans")
}

// ============================================================
// ATTACHMENTS
// ============================================================

// Polymorphic attachment — entityType discriminates the target (e.g. "JOURNAL_ENTRY", "INVOICE")
// No FK constraint because one entityId cannot reference multiple tables simultaneously.
model Attachment {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  uploadedBy  String
  uploadedAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("attachments")
}
